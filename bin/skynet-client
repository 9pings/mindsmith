#!/usr/bin/env node
'use strict';
// skynet-client — the local appliance.
//   skynet-client serve   [--port N] [--store <f.json>] [--sgc <dir>] [--catalog <url>] [--refresh <s>]
//                         backends: env FRONTIER_MODEL=<path.gguf> (embedded) | LLM_BASE (endpoint);
//                         optional env LOCAL_MODEL=<path.gguf> (semantic coverage); CATALOG_TOKEN.
//   skynet-client pull    [--catalog <url>] [--sgc <dir>]        one-shot catalog sync (integrity-checked)
const { createApp } = require('../lib/app.js');
const { pullAll } = require('../lib/sgc-sync.js');

const argv = process.argv.slice(2);
const cmd = argv[0];
const flag = ( n ) => { const i = argv.indexOf('--' + n); return i !== -1 ? argv[i + 1] : undefined; };
const catalogUrl = flag('catalog') || process.env.CATALOG_URL;
const token = flag('key') || process.env.CATALOG_TOKEN;
const sgcDir = flag('sgc') || 'sgc';

if ( cmd === 'pull' ) {
	if ( !catalogUrl ) { console.error('pull needs --catalog <url> (or env CATALOG_URL)'); process.exit(1); }
	pullAll({ url: catalogUrl, token, dir: sgcDir })
		.then(( r ) => { console.log('pulled=' + r.pulled.join(',') + ' skipped=' + r.skipped.length + ' rejected=' + JSON.stringify(r.rejected)); process.exit(r.rejected.length ? 2 : 0); })
		.catch(( e ) => { console.error(e.message); process.exit(1); });
} else if ( cmd === 'serve' || cmd === undefined ) {
	let frontierChat;
	if ( process.env.FRONTIER_MODEL ) frontierChat = require('skynet-graph/lib/providers/llm-local.js').makeLocalAsk({ modelPath: process.env.FRONTIER_MODEL, reasoningBudget: 0 });
	else if ( process.env.LLM_BASE ) frontierChat = require('skynet-graph/lib/providers/llm.js').makeAsk({ base: process.env.LLM_BASE, model: process.env.LLM_MODEL || 'default' });
	else { console.error('serve needs a frontier: env FRONTIER_MODEL=<path.gguf> or LLM_BASE=<url>'); process.exit(1); }
	const localAsk = process.env.LOCAL_MODEL ? require('skynet-graph/lib/providers/llm-local.js').makeLocalAsk({ modelPath: process.env.LOCAL_MODEL, reasoningBudget: 0 }) : undefined;
	const app = createApp({
		frontierChat, localAsk,
		store: flag('store') || '.skynet-stock.json', sgcDir,
		catalog: catalogUrl ? { url: catalogUrl, token, refresh: flag('refresh') } : undefined,
		port: Number(flag('port')) || 4747,
		onAnswer: ( row ) => console.error('[' + (row.source === 'local' ? 'cache' : 'frontier') + '] ' + row.query)
	});
	app.start(( first ) => {
		const l = first.loaded;
		console.log('skynet-client → http://127.0.0.1:' + (Number(flag('port')) || 4747) + '/v1   (OpenAI-compatible)');
		console.log('sgc: methods=' + l.methods.length + ' lattice=' + l.lattice.length + (first.pulled ? '  pulled=' + first.pulled.pulled.length + ' rejected=' + first.pulled.rejected.length : '  (no catalog configured)'));
	}).catch(( e ) => { console.error(e.message); process.exit(1); });
	process.on('SIGINT', () => { app.stop(); process.exit(0); });
} else {
	console.error('usage: skynet-client serve|pull …');
	process.exit(1);
}
